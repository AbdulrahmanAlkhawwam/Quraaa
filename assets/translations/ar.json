        "desc": "\u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645\u0643 \u0644\u0642\u0631\u0627\u0621\u060c \u062a\u0624\u0643\u062f \u0623\u0646\u0643 \u0642\u062f \u0642\u0631\u0623\u062a \u0648\u0641\u0647\u0645\u062a \u0648\u0648\u0627\u0641\u0642\u062a \u0639\u0644\u0649 \u0627\u0644\u0627\u0646\u062a\u0638\u0627\u0645 \u0628\u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645 \u0648\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0646\u0627."
      },
      "eligibility": {
        "title": "\u0623\u0647\u0644\u064a\u0629 \u0627\u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645",
        "desc": "\u064a\u062c\u0628 \u0623\u0646 \u062a\u0643\u0648\u0646 \u0639\u0644\u0649 \u0627\u0644\u0623\u0642\u0644 \u0627\u0644\u0633\u0646 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a \u0627\u0644\u0645\u0637\u0644\u0648\u0628 \u0641\u064a \u0628\u0644\u062f\u0643 \u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0642\u0631\u0627\u0621\u060c \u0623\u0648 \u0623\u0646 \u062a\u062d\u0635\u0644 \u0639\u0644\u0649 \u0625\u0630\u0646 \u0645\u0646 \u0648\u0627\u0644\u062f\u0643 \u0623\u0648 \u0627\u0644\u0648\u0635\u064a \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a \u0644\u0643."
      },
      "user_account": {
        "title": "\u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0634\u062e\u0635\u064a",
        "desc": "\u0639\u0646\u062f \u0625\u0646\u0634\u0627\u0621 \u062d\u0633\u0627\u0628\u060c \u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649: \u062a\u0642\u062f\u064a\u0645 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u062f\u0642\u064a\u0642\u0629 \u0648\u0643\u0627\u0645\u0644\u0629. \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0623\u0645\u0627\u0646 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u062d\u0633\u0627\u0628. \u0627\u0644\u0645\u0633\u0624\u0648\u0644\u064a\u0629 \u0639\u0646 \u062c\u0645\u064a\u0639 \u0627\u0644\u0623\u0646\u0634\u0637\u0629 \u062a\u062d\u062a \u0627\u0644\u062d\u0633\u0627\u0628. \u0625\u062e\u0637\u0627\u0631\u0646\u0627 \u0641\u0648\u0631\u0627\u064b \u0625\u0630\u0627 \u0638\u0646\u0646\u062a \u0623\u0646 \u062d\u0633\u0627\u0628\u0643 \u0642\u062f \u062a\u0645 \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u064a\u0647 \u0628\u062f\u0648\u0646 \u0625\u0630\u0646\u0643."
      },
      "use_of_platform": {
        "title": "\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0646\u0635\u0629",
        "desc": "\u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0642\u0631\u0627\u0621 \u0641\u0642\u0637 \u0644\u0644\u0623\u063a\u0631\u0627\u0636 \u0627\u0644\u0645\u0634\u0631\u0648\u0639\u0629. \u0644\u0627 \u064a\u062c\u0648\u0632 \u0644\u0643: \u0627\u0646\u062a\u0647\u0627\u0643 \u0623\u064a \u0642\u0627\u0646\u0648\u0646 \u0623\u0648 \u0644\u0648\u0627\u0626\u062d \u0645\u0637\u0628\u0642\u0629. \u0645\u0634\u0627\u0631\u0643\u0629 \u0645\u062d\u062a\u0648\u0649 \u0645\u062d\u0645\u064a \u0628\u062d\u0642\u0648\u0642 \u0627\u0644\u0646\u0634\u0631 \u0628\u062f\u0648\u0646 \u0625\u0630\u0646. \u062a\u062d\u0645\u064a\u0644 \u0628\u0631\u0627\u0645\u062c \u0636\u0627\u0631\u0629 \u0623\u0648 \u0645\u062d\u062a\u0648\u0649 \u0636\u0627\u0631. \u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u0649 \u0623\u0646\u0638\u0645\u0629 \u0623\u0648 \u0628\u064a\u0627\u0646\u0627\u062a \u0628\u062f\u0648\u0646 \u062a\u0641\u0648\u064a\u0636. \u0627\u0644\u0645\u0636\u0627\u064a\u0642\u0629 \u0623\u0648 \u0627\u0644\u062a\u0647\u062f\u064a\u062f \u0623\u0648 \u0625\u0633\u0627\u0621\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0622\u062e\u0631\u064a\u0646. \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0623\u062f\u0648\u0627\u062a \u0622\u0644\u064a\u0629 \u0644\u062c\u0645\u0639 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0628\u062f\u0648\u0646 \u0625\u0630\u0646."
      },
      "digital_content": {
        "title": "\u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0631\u0642\u0645\u064a",
        "desc": "\u0627\u0644\u0643\u062a\u0628 \u0648\u0627\u0644\u0643\u062a\u0628 \u0627\u0644\u0635\u0648\u062a\u064a\u0629 \u0648\u0627\u0644\u0645\u0644\u062e\u0635\u0627\u062a \u0648\u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0631\u0642\u0645\u064a \u0627\u0644\u0622\u062e\u0631 \u0627\u0644\u0645\u062a\u0648\u0641\u0631 \u0639\u0644\u0649 \u0642\u0631\u0627\u0621 \u0645\u062d\u0645\u064a \u0628\u062d\u0642\u0648\u0642 \u0627\u0644\u0646\u0634\u0631 \u0648\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0641\u0643\u0631\u064a\u0629. \u0625\u0644\u0627 \u0625\u0630\u0627 \u0643\u0627\u0646 \u0645\u0645\u0643\u0646\u0627\u064b \u0635\u0631\u064a\u062d\u0627\u064b\u060c \u0644\u0627 \u064a\u062c\u0648\u0632 \u0644\u0643: \u0627\u0644\u0646\u0633\u062e\u060c \u0627\u0644\u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u062a\u0648\u0632\u064a\u0639\u060c \u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0628\u064a\u0639\u060c \u0627\u0644\u062a\u0639\u062f\u064a\u0644\u060c \u0627\u0644\u0646\u0634\u0631\u060c \u0623\u0648 \u0645\u0634\u0627\u0631\u0643\u0629 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0631\u0642\u0645\u064a \u0627\u0644\u0645\u0634\u062a\u0631\u0649. \u0645\u0634\u062a\u0631\u064a\u0627\u062a\u0643 \u062a\u0645\u0646\u062d\u0643 \u062a\u0631\u062e\u064a\u0635\u0627\u064b \u0634\u062e\u0635\u064a\u0627\u064b \u063a\u064a\u0631 \u0642\u0627\u0628\u0644 \u0644\u0644\u062a\u0646\u0627\u0632\u0644."
      },
      "marketplace": {
        "title": "\u0627\u0644\u0633\u0648\u0642",
        "desc": "\u064a\u0645\u0643\u0646 \u0644\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0634\u0631\u0627\u0621 \u0623\u0648 \u0628\u064a\u0639 \u0627\u0644\u0643\u062a\u0628 \u0627\u0644\u0645\u0633\u0645\u0648\u062d \u0628\u0647\u0627 \u0639\u0628\u0631 \u0642\u0631\u0627\u0621. \u0627\u0644\u0628\u0627\u0626\u0639\u0648\u0646 \u0645\u0633\u0624\u0648\u0644\u0648\u0646 \u0639\u0646: \u0648\u0635\u0641\u0627\u062a \u062f\u0642\u064a\u0642\u0629 \u0644\u0644\u0645\u0646\u062a\u062c\u0627\u062a. \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629 \u0644\u0644\u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u0645\u0645\u0641\u0648\u0636\u0629. \u0634\u062d\u0646 \u0627\u0644\u0643\u062a\u0628 \u0627\u0644\u0645\u0637\u0628\u0648\u0639\u0629 \u0639\u0646\u062f \u0627\u0644\u0627\u0642\u062a\u0636\u0627\u0621. \u0642\u062f \u062a\u0642\u0648\u0645 \u0642\u0631\u0627\u0621 \u0628\u0625\u0632\u0627\u0644\u0629 \u0627\u0644\u0642\u0648\u0627\u0626\u0645 \u0627\u0644\u062a\u064a \u062a\u0646\u062a\u0647\u0643 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637."
      },
      "author_content": {
        "title": "\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u0624\u0644\u0641\u064a\u0646",
        "desc": "\u064a\u062d\u062a\u0641\u0638 \u0627\u0644\u0645\u0624\u0644\u0641\u0648\u0646 \u0628\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0630\u064a \u064a\u0646\u0634\u0631\u0648\u0646\u0647. \u0628\u0627\u0644\u0646\u0634\u0631 \u0639\u0644\u0649 \u0642\u0631\u0627\u0621\u060c \u062a\u0645\u0646\u062d\u0643 \u062a\u0631\u062e\u064a\u0635\u0627\u064b \u063a\u064a\u0631 \u062d\u0635\u0631\u064a \u0644\u0627\u0633\u062a\u0636\u0627\u0641\u0629\u060c \u0648\u0639\u0631\u0636\u060c \u0648\u062a\u0648\u0632\u064a\u0639 \u0648\u062a\u0631\u0648\u064a\u062c \u0645\u062d\u062a\u0648\u0627\u0643 \u0639\u0628\u0631 \u0627\u0644\u0645\u0646\u0635\u0629. \u0627\u0644\u0645\u0624\u0644\u0641\u0648\u0646 \u0645\u0633\u0624\u0648\u0644\u0648\u0646 \u0639\u0646 \u0627\u0644\u062a\u0623\u0643\u062f \u0645\u0646 \u0623\u0646\u0647\u0645 \u064a\u0645\u0644\u0643\u0648\u0646 \u062c\u0645\u064a\u0639 \u0627\u0644\u062d\u0642\u0648\u0642 \u0641\u064a \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0630\u064a \u064a\u0642\u0648\u0645\u0648\u0646 \u0628\u0631\u0641\u0639\u0647."
      },
      "ai_features": {
        "title": "\u0645\u064a\u0632\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a",
        "desc": "\u0642\u062f \u062a\u0648\u0641\u0631 \u0642\u0631\u0627\u0621 \u062e\u062f\u0645\u0627\u062a \u0645\u062f\u0639\u0648\u0645\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0628\u0645\u0627 \u0641\u064a \u0630\u0644\u0643: \u0645\u0644\u062e\u0635\u0627\u062a \u0627\u0644\u0643\u062a\u0628\u060c \u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0629 \u0641\u064a \u0627\u0644\u0642\u0631\u0627\u0621\u0629\u060c \u0627\u0644\u062a\u0648\u0635\u064a\u0627\u062a\u060c \u062f\u0639\u0645 \u0627\u0644\u062a\u0631\u062c\u0645\u0629. \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u0646\u0634\u0623 \u0628\u0648\u0627\u0633\u0637\u0629 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0645\u0642\u062f\u0645 \u0644\u0623\u063a\u0631\u0627\u0636 \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u064a\u0629 \u0641\u0642\u0637 \u0648\u0642\u062f \u0644\u0627 \u064a\u0643\u0648\u0646 \u062f\u0627\u0626\u0645\u0627\u064b \u062f\u0642\u064a\u0642\u0627\u064b \u0623\u0648 \u0643\u0627\u0645\u0644\u0627\u064b."
      },
      "community_guidelines": {
        "title": "\u0625\u0631\u0634\u0627\u062f\u0627\u062a \u0627\u0644\u0645\u062c\u062a\u0645\u0639",
        "desc": "\u064a\u062c\u0628 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0628\u0627\u062d\u062a\u0631\u0627\u0645. \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u062a\u0627\u0644\u064a \u0645\u0645\u0646\u0648\u0639: \u0627\u0644\u0643\u0631\u0627\u0647\u064a\u0629\u060c \u0627\u0644\u0645\u0636\u0627\u064a\u0642\u0629\u060c \u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u063a\u064a\u0631 \u0645\u0631\u063a\u0648\u0628\u0629\u060c \u0627\u0644\u0627\u062d\u062a\u064a\u0627\u0644\u060c \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u063a\u064a\u0631 \u0642\u0627\u0646\u0648\u0646\u064a\u060c \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u0647\u064a\u0646 \u0623\u0648 \u0627\u0644\u0636\u0627\u0631. \u0646\u062d\u062a\u0641\u0638 \u0628\u062d\u0642\u0646\u0627 \u0641\u064a \u0625\u0632\u0627\u0644\u0629 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0623\u0648 \u062a\u0639\u0644\u064a\u0642 \u0627\u0644\u062d\u0633\u0627\u0628\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0646\u062a\u0647\u0643 \u0647\u0630\u0647 \u0627\u0644\u0625\u0631\u0634\u0627\u062f\u0627\u062a."
      },
      "payments": {
        "title": "\u0627\u0644\u062f\u0641\u0639\u0627\u062a",
        "desc": "\u062a\u062a\u0637\u0644\u0628 \u0645\u064a\u0632\u0627\u062a \u0645\u0639\u064a\u0646\u0629 \u0627\u0644\u062f\u0641\u0639. \u0628\u0625\u062c\u0631\u0627\u0621 \u0627\u0644\u0634\u0631\u0627\u0621\u060c \u062a\u0648\u0627\u0641\u0642 \u0639\u0644\u0649 \u0623\u0646: \u0627\u0644\u0623\u0633\u0639\u0627\u0631 \u0642\u062f \u062a\u062a\u063a\u064a\u0631 \u0628\u062f\u0648\u0646 \u0625\u0634\u0639\u0627\u0631 \u0645\u0633\u0628\u0642. \u062a\u062a\u0645 \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u062f\u0641\u0639\u0627\u062a \u0639\u0628\u0631 \u0645\u0632\u0648\u062f\u064a \u0627\u0644\u062f\u0641\u0639 \u0627\u0644\u0645\u0639\u062a\u0645\u062f\u064a\u0646. \u0642\u062f \u062a\u0646\u0637\u0628\u0642 \u0627\u0644\u0636\u0631\u0627\u0626\u0628 \u0628\u0627\u0631\u062a\u0643\u0627\u0632\u0627\u064b \u0645\u0639 \u0645\u0648\u0642\u0639\u0643."
      },
      "subscriptions": {
        "title": "\u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643\u0627\u062a",
        "desc": "\u062a\u062a\u0645 \u0625\u0639\u0627\u062f\u0629 \u062e\u0637\u0637 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643 \u0641\u064a \u0648\u0642\u062a \u0645\u062d\u062f\u062f \u0628\u0645\u0648\u062c\u0628 \u062f\u0648\u0631\u0629 \u0627\u0644\u0641\u0648\u062a\u0631\u0629 \u0625\u0644\u0627 \u0625\u0630\u0627 \u062a\u0645 \u0625\u0644\u063a\u0627\u0624\u0647\u0627 \u0642\u0628\u0644 \u0627\u0644\u062a\u062c\u062f\u064a\u062f. \u0642\u062f \u062a\u062a\u063a\u064a\u0631 \u0645\u0627\u0632\u0627\u064a\u0627 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643 \u0645\u0639 \u062a\u0637\u0648\u0631 \u0627\u0644\u0645\u0646\u0635\u0629."
      },
      "refund_policy": {
        "title": "\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u0625\u0631\u062c\u0627\u0639",
        "desc": "\u064a\u0639\u062a\u0645\u062f \u0623\u0647\u0644\u064a\u0629 \u0627\u0644\u0625\u0631\u062c\u0627\u0639 \u0639\u0644\u0649 \u0646\u0648\u0639 \u0627\u0644\u0634\u0631\u0627\u0621 \u0648\u0627\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0637\u0628\u0642\u0629. \u0642\u062f \u0644\u0627 \u062a\u0643\u0648\u0646 \u0645\u0634\u062a\u0631\u064a\u0627\u062a \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0631\u0642\u0645\u064a \u0642\u0627\u0628\u0644\u0629 \u0644\u0644\u0625\u0631\u062c\u0627\u0639 \u0628\u0645\u062c\u0631\u062f \u0627\u0644\u0648\u0635\u0648\u0644 \u0625\u0644\u064a\u0647\u0627 \u0625\u0644\u0627 \u0625\u0630\u0627 \u0627\u0634\u062a\u0631\u062a \u0627\u0644\u0642\u0627\u0646\u0648\u0646."
      },
      "privacy": {
        "title": "\u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629",
        "desc": "\u0627\u0633\u062a\u062e\u062f\u0627\u0645\u0643 \u0644\u0642\u0631\u0627\u0621 \u0645\u0646\u0636\u0648\u0631 \u0623\u064a\u0636\u0627\u064b \u0628\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u062e\u0635\u0648\u0635\u064a\u0629 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0646\u0627\u060c \u0627\u0644\u062a\u064a \u062a\u0634\u0631\u062d \u0643\u064a\u0641\u064a\u0629 \u062c\u0645\u0639 \u0648\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0648\u062d\u0645\u0627\u064a\u0629 \u0645\u0639\u0644\u0648\u0645\u0627\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629."
      },
      "intellectual_property": {
        "title": "\u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0641\u0643\u0631\u064a\u0629",
        "desc": "\u062c\u0645\u064a\u0639 \u0639\u0644\u0627\u0645\u0627\u062a \u0627\u0644\u0645\u0646\u0635\u0629 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0648\u0627\u0644\u0634\u0639\u0627\u0631\u0627\u062a \u0648\u0627\u0644\u062a\u0635\u0645\u064a\u0645\u0627\u062a \u0648\u0627\u0644\u0628\u0631\u0627\u0645\u062c \u0648\u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0645\u0645\u0644\u0643\u0629 \u0644\u0642\u0631\u0627\u0621 \u0623\u0648 \u0645\u0648\u0641\u0631\u064a\u0647\u0627 \u0648\u0645\u062d\u0645\u064a\u0629 \u0628\u0645\u0648\u062c\u0628 \u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0641\u0643\u0631\u064a\u0629 \u0627\u0644\u0645\u0637\u0628\u0642\u0629."
      },
      "service_availability": {
        "title": "\u062a\u0648\u0641\u0631 \u0627\u0644\u062e\u062f\u0645\u0629",
        "desc": "\u0646\u0633\u0639\u0649 \u0644\u062a\u0648\u0641\u064a\u0631 \u0648\u0635\u0648\u0644 \u0645\u0633\u062a\u0645\u0631 \u0644\u0643\u0646 \u0644\u0627 \u064a\u0645\u0643\u0646\u0646\u0627 \u0636\u0645\u0627\u0646 \u0623\u0646 \u062a\u0643\u0648\u0646 \u0627\u0644\u0645\u0646\u0635\u0629 \u0645\u062a\u0648\u0641\u0631\u0629 \u062f\u0627\u0626\u0645\u0627\u064b. \u0642\u062f \u062a\u0624\u062b\u0631 \u0627\u0644\u0635\u064a\u0627\u0646\u0629 \u0648\u0627\u0644\u062a\u062d\u062f\u064a\u062b\u0627\u062a \u0623\u0648 \u0627\u0644\u0645\u0634\u0627\u0643\u0644 \u0627\u0644\u062a\u0642\u0646\u064a\u0629 \u0628\u0634\u0643\u0644 \u0645\u0624\u0642\u062a \u0639\u0644\u0649 \u062a\u0648\u0641\u0631 \u0627\u0644\u062e\u062f\u0645\u0629."
      },
      "account_suspension": {
        "title": "\u0625\u064a\u0642\u0627\u0641 \u0627\u0644\u062d\u0633\u0627\u0628",
        "desc": "\u0642\u062f \u0646\u0639\u0644\u0642 \u0623\u0648 \u0646\u062d\u0630\u0641 \u0627\u0644\u062d\u0633\u0627\u0628\u0627\u062a \u0627\u0644\u062a\u064a: \u062a\u0646\u062a\u0647\u0643 \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637. \u062a\u062a\u0648\u0631\u0637 \u0641\u064a \u0646\u0634\u0627\u0637 \u0627\u062d\u062a\u064a\u0627\u0644\u064a. \u062a\u062a\u0639\u0628\u062b \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0646\u0635\u0629. \u062a\u0646\u062a\u0647\u0643 \u062d\u0642\u0648\u0642 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0641\u0643\u0631\u064a\u0629."
      },
      "limitation_of_liability": {
        "title": "\u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0645\u0633\u0624\u0648\u0644\u064a\u0629",
        "desc": "\u0628\u0642\u062f\u0631 \u0627\u0644\u0645\u0645\u0643\u0646 \u0627\u0644\u0645\u0633\u0645\u0648\u062d \u0628\u0647 \u0642\u0627\u0646\u0648\u0646\u064a\u0627\u064b\u060c \u0644\u0646 \u062a\u0643\u0648\u0646 \u0642\u0631\u0627\u0621 \u0645\u0633\u0624\u0648\u0644\u0629 \u0639\u0646 \u0623\u0636\u0631\u0627\u0631 \u063a\u064a\u0631 \u0645\u0628\u0627\u0634\u0631\u0629 \u0623\u0648 \u0648\u0641\u064a\u0629 \u0623\u0648 \u062a\u0628\u0639\u064a\u0629 \u0646\u0627\u062c\u0645\u0629 \u0639\u0646 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0646\u0635\u0629."
      },
      "changes_to_terms": {
        "title": "\u062a\u063a\u064a\u064a\u0631\u0627\u062a \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637",
        "desc": "\u0642\u062f \u0646\u0642\u0648\u0645 \u0628\u062a\u062d\u062f\u064a\u062b \u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645 \u0645\u0646 \u062d\u064a\u0646 \u0644\u0622\u062e\u0631. \u0633\u064a\u062a\u0645 \u0627\u0644\u0627\u062e\u0637\u0627\u0631 \u0628\u0627\u0644\u062a\u063a\u064a\u064a\u0631\u0627\u062a \u0627\u0644\u0645\u0647\u0645\u0629 \u0639\u0628\u0631 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0623\u0648 \u0642\u0646\u0648\u0627\u062a \u0623\u062e\u0631\u0649 \u0645\u0646\u0627\u0633\u0628\u0629. \u064a\u0634\u0643\u0644 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0642\u0631\u0627\u0621 \u0628\u0639\u062f \u0627\u0644\u062a\u062d\u062f\u064a\u062b\u0627\u062a \u0642\u0628\u0648\u0644\u0627\u064b \u0644\u0644\u0634\u0631\u0648\u0637 \u0627\u0644\u0645\u0631\u0627\u062c\u0639\u0629."
      },
      "contact_us": {
        "title": "\u0627\u062a\u0635\u0644 \u0628\u0646\u0627",
        "desc": "\u0625\u0630\u0627 \u0643\u0627\u0646\u0644\u0643 \u0623\u064a \u0627\u0633\u062a\u0641\u0633\u0627\u0631\u0627\u062a \u062a\u062a\u0639\u0644\u0642 \u0628\u0647\u0630\u0647 \u0627\u0644\u0634\u0631\u0648\u0637 \u0648\u0627\u0644\u0623\u062d\u0643\u0627\u0645\u060c \u064a\u0631\u062c\u0649 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627 \u0639\u0628\u0631 \u0642\u0646\u0648\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0645\u0648\u062c\u0648\u062f\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642."
