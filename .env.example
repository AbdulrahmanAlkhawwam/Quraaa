# Copy this file to .env and fill in real values for local development.
# The terminal scripts whitelist runtime values and pass them via --dart-define.
# NEVER commit .env, add it to Flutter assets, or pass the whole file to Flutter.
HOST=api.quraa.dev
BASEURL=api
APP_ENV=development
LATEST_VERSION=1.0.0

# Firebase App Distribution (Android)
# Get the App ID from the Firebase Console > Project settings > Your apps > Android
# or from android/app/google-services.json (mobilesdk_app_id) or firebase.json.
FIREBASE_ANDROID_APP_ID=1:YOUR_PROJECT_NUMBER:android:YOUR_MOBILE_SDK_ID

# Comma-separated list of Firebase App Distribution tester group names, e.g. "qa-team,beta-testers".
FIREBASE_TESTER_GROUPS=beta-testers

# Optional: Firebase project ID. Used by the Firebase CLI when no default project is selected.
# FIREBASE_PROJECT_ID=quraa-otp

# Optional: path to a Google service account JSON key for non-interactive (CI) uploads.
# For local development run `firebase login` instead and leave this empty.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional: legacy Firebase CLI token. Prefer GOOGLE_APPLICATION_CREDENTIALS for CI.
# FIREBASE_TOKEN=your_firebase_cli_token
